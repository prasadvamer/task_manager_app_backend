# syntax=docker/dockerfile:1

# Development-only Dockerfile for Rails API
# - Installs build tooling and Postgres client headers
# - Uses a writable bundle path mounted as a volume for fast gem installs

ARG RUBY_VERSION=4.0.5
FROM docker.io/library/ruby:${RUBY_VERSION}-bookworm

ENV BUNDLE_PATH="/usr/local/bundle" \
    RAILS_ENV=development

WORKDIR /rails

# OS packages for building native gems and talking to Postgres
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      libyaml-dev \
      pkg-config \
      libpq-dev \
      postgresql-client && \
    ln -sf /usr/share/zoneinfo/Asia/Tokyo /etc/localtime && \
    dpkg-reconfigure -f noninteractive tzdata && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Install gems first to leverage Docker layer caching
COPY Gemfile Gemfile.lock ./
RUN bundle install && \
    rm -rf "$BUNDLE_PATH"/ruby/*/cache "$BUNDLE_PATH"/ruby/*/bundler/gems/*/.git

# Copy application code (will be overridden by bind mount in compose during dev)
COPY . .

# Run and own only the runtime files as a non-root user for security
RUN useradd rails --create-home --shell /bin/bash && \
    chown -R rails:rails /rails
USER rails:rails

# Prepare DB automatically when running the server
ENTRYPOINT ["/rails/bin/docker-entrypoint"]

# Default dev command
CMD ["./bin/rails", "server", "-b", "0.0.0.0", "-p", "3000"]
